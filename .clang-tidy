# Simplified clang-tidy configuration for sudoku-cpp project
# Focus on most important checks with minimal false positives

Checks: '
  -*,
  bugprone-*,
  cert-*,
  clang-analyzer-*,
  cppcoreguidelines-*,
  modernize-*,
  performance-*,
  readability-*,
  -bugprone-easily-swappable-parameters,
  -cppcoreguidelines-avoid-magic-numbers,
  -cppcoreguidelines-macro-usage,
  -cppcoreguidelines-non-private-member-variables-in-classes,
  -cppcoreguidelines-pro-bounds-array-to-pointer-decay,
  -cppcoreguidelines-pro-bounds-constant-array-index,
  -cppcoreguidelines-pro-type-reinterpret-cast,
  -modernize-use-trailing-return-type,
  -readability-avoid-const-params-in-decls,
  -readability-magic-numbers,
  -readability-named-parameter,
  -cppcoreguidelines-pro-bounds-pointer-arithmetic,
  -cppcoreguidelines-pro-type-vararg,
  -readability-implicit-bool-conversion,
  -readability-uppercase-literal-suffix
'

# Only analyze project files, ignore system headers and third-party code
# Exclude imgui_backends directory (third-party code)
HeaderFilterRegex: 'src/(?!imgui_backends).*\.h$'

# Analysis options
FormatStyle: file

# Key check options
CheckOptions:
  - key: modernize-loop-convert.MaxCopySize
    value: 16
  - key: modernize-use-nullptr.NullMacros
    value: 'NULL'
  - key: performance-for-range-copy.WarnOnAllAutoCopies
    value: false
  - key: readability-function-cognitive-complexity.Threshold
    value: 25
  - key: readability-function-size.LineThreshold
    value: 100
  - key: readability-identifier-length.MinimumVariableNameLength
    value: 1
  - key: readability-identifier-length.MinimumLoopCounterNameLength
    value: 1
  - key: readability-identifier-length.MinimumParameterNameLength
    value: 1
